// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`ErrorState > renders with custom error message 1`] = `"<div class="flex flex-col items-center justify-center py-24 text-center px-4"><p class="text-gray-600 text-sm font-semibold mb-4">Network error occurred.</p> <button class="bg-primary text-white font-bold rounded-md px-6 py-2 hover:opacity-90 transition-opacity">Retry</button></div>"`;

exports[`ErrorState > renders with default message 1`] = `"<div class="flex flex-col items-center justify-center py-24 text-center px-4"><p class="text-gray-600 text-sm font-semibold mb-4">Something went wrong. Please try again.</p> <button class="bg-primary text-white font-bold rounded-md px-6 py-2 hover:opacity-90 transition-opacity">Retry</button></div>"`;
