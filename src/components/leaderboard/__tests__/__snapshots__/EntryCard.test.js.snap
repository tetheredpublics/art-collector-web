// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`EntryCard > renders entry with empty metrics 1`] = `"<div class="bg-white border border-appGreyBorder rounded-lg p-3 flex items-start gap-3 hover:shadow-md transition-shadow border-l-4 border-appYellow"><div class="flex-shrink-0"><div class="size-12 rounded-md overflow-hidden relative" style="background-color: rgb(207, 45, 45); border-right: 3px solid rgb(153, 33, 33);"><img src="https://example.com/avatar.png" alt="xellon's avatar" class="size-12 object-cover" loading="lazy"></div></div> <div class="flex-1 min-w-0"><div class="flex items-baseline justify-between gap-1"><span class="text-sm font-bold text-gray-800 truncate">xellon</span> <span class="text-xs font-semibold text-gray-500 flex-shrink-0">+300XP</span></div> </div> <div class="flex flex-col items-center flex-shrink-0 ml-1"><span class="text-xs text-green-600" aria-label="Rank moved up">▲</span> <span class="text-sm font-black text-gray-800">#1</span> </div></div>"`;

exports[`EntryCard > renders last week winner icon when isLastWeeksWinner and categoryIconSrc provided 1`] = `"<div class="bg-white border border-appGreyBorder rounded-lg p-3 flex items-start gap-3 hover:shadow-md transition-shadow border-l-4 border-appYellow"><div class="flex-shrink-0"><div class="size-12 rounded-md overflow-hidden relative" style="background-color: rgb(207, 45, 45); border-right: 3px solid rgb(153, 33, 33);"><img src="https://example.com/avatar.png" alt="xellon's avatar" class="size-12 object-cover" loading="lazy"></div></div> <div class="flex-1 min-w-0"><div class="flex items-baseline justify-between gap-1"><span class="text-sm font-bold text-gray-800 truncate">xellon</span> <span class="text-xs font-semibold text-gray-500 flex-shrink-0">+300XP</span></div> <div class="flex gap-3 mt-1"><div class="flex items-center gap-1" title="Collected"><img src="/icons/collect.png" alt="Collected" class="size-4"> <span class="text-xs text-gray-600">3</span> </div><div class="flex items-center gap-1" title="Dropped"><img src="/icons/drop.png" alt="Dropped" class="size-4"> <span class="text-xs text-gray-600">0</span> </div><div class="flex items-center gap-1" title="Destroyed"><img src="/icons/destroy.png" alt="Destroyed" class="size-4"> <span class="text-xs text-gray-600">3</span> </div></div></div> <div class="flex flex-col items-center flex-shrink-0 ml-1"><span class="text-xs text-green-600" aria-label="Rank moved up">▲</span> <span class="text-sm font-black text-gray-800">#1</span> <div class="mt-0.5 size-5 rounded-full flex items-center justify-center" style="background-color: rgba(237, 216, 83, 0.25); box-shadow: 0 0 0 2px #EDD853;"><img src="/icons/leaderboard/trophy.svg" alt="Last week's winner" class="size-3"></div></div></div>"`;

exports[`EntryCard > renders rank 1 entry with gold left border 1`] = `"<div class="bg-white border border-appGreyBorder rounded-lg p-3 flex items-start gap-3 hover:shadow-md transition-shadow border-l-4 border-appYellow"><div class="flex-shrink-0"><div class="size-12 rounded-md overflow-hidden relative" style="background-color: rgb(207, 45, 45); border-right: 3px solid rgb(153, 33, 33);"><img src="https://example.com/avatar.png" alt="xellon's avatar" class="size-12 object-cover" loading="lazy"></div></div> <div class="flex-1 min-w-0"><div class="flex items-baseline justify-between gap-1"><span class="text-sm font-bold text-gray-800 truncate">xellon</span> <span class="text-xs font-semibold text-gray-500 flex-shrink-0">+300XP</span></div> <div class="flex gap-3 mt-1"><div class="flex items-center gap-1" title="Collected"><img src="/icons/collect.png" alt="Collected" class="size-4"> <span class="text-xs text-gray-600">3</span> </div><div class="flex items-center gap-1" title="Dropped"><img src="/icons/drop.png" alt="Dropped" class="size-4"> <span class="text-xs text-gray-600">0</span> </div><div class="flex items-center gap-1" title="Destroyed"><img src="/icons/destroy.png" alt="Destroyed" class="size-4"> <span class="text-xs text-gray-600">3</span> </div></div></div> <div class="flex flex-col items-center flex-shrink-0 ml-1"><span class="text-xs text-green-600" aria-label="Rank moved up">▲</span> <span class="text-sm font-black text-gray-800">#1</span> </div></div>"`;

exports[`EntryCard > renders rank 2 entry with silver left border 1`] = `"<div class="bg-white border border-appGreyBorder rounded-lg p-3 flex items-start gap-3 hover:shadow-md transition-shadow border-l-4 border-gray-300"><div class="flex-shrink-0"><div class="size-12 rounded-md overflow-hidden relative" style="background-color: rgb(207, 45, 45); border-right: 3px solid rgb(153, 33, 33);"><img src="https://example.com/avatar.png" alt="xellon's avatar" class="size-12 object-cover" loading="lazy"></div></div> <div class="flex-1 min-w-0"><div class="flex items-baseline justify-between gap-1"><span class="text-sm font-bold text-gray-800 truncate">xellon</span> <span class="text-xs font-semibold text-gray-500 flex-shrink-0">+300XP</span></div> <div class="flex gap-3 mt-1"><div class="flex items-center gap-1" title="Collected"><img src="/icons/collect.png" alt="Collected" class="size-4"> <span class="text-xs text-gray-600">3</span> </div><div class="flex items-center gap-1" title="Dropped"><img src="/icons/drop.png" alt="Dropped" class="size-4"> <span class="text-xs text-gray-600">0</span> </div><div class="flex items-center gap-1" title="Destroyed"><img src="/icons/destroy.png" alt="Destroyed" class="size-4"> <span class="text-xs text-gray-600">3</span> </div></div></div> <div class="flex flex-col items-center flex-shrink-0 ml-1"><span class="text-xs text-green-600" aria-label="Rank moved up">▲</span> <span class="text-sm font-black text-gray-800">#2</span> </div></div>"`;
